ROUTEWEILER_TEST_PRIVATE_KEY=0x...

# Address that receives the 0.0001 USDC test payment.
ROUTEWEILER_TEST_MERCHANT_RECIPIENT=0x...

# Can be the same as above
ROUTEWEILER_TEST_TEMPO_PRIVATE_KEY=
ROUTEWEILER_TEST_TEMPO_RECIPIENT=

# Optional — defaults to https://www.x402.org/facilitator
# ROUTEWEILER_TEST_FACILITATOR_URL=https://www.x402.org/facilitator

# gRPC endpoint for the payer node (host:port)
POLAR_LND_HOST=
# Path to payer node TLS cert
POLAR_LND_TLS_CERT=
# Path to payer node admin.macaroon
POLAR_LND_MACAROON=
# gRPC endpoint for the merchant node (host:port)
POLAR_MERCHANT_HOST=
# Path to merchant node TLS cert
POLAR_MERCHANT_TLS_CERT=
# Path to merchant node admin.macaroon
POLAR_MERCHANT_MACAROON=

# Stripe secret key in test mode (sk_test_...)
STRIPE_TEST_API_KEY=
# Stripe test customer id (cus_...)
STRIPE_TEST_CUSTOMER=
# Saved Stripe test payment method id (pm_...)
STRIPE_TEST_PAYMENT_METHOD=
# Seller's Stripe network business profile id (profile_...)
STRIPE_TEST_SELLER_PROFILE=